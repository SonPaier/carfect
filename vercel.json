{
  "buildCommand": "pnpm --filter carfect run build",
  "outputDirectory": "apps/carfect/dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.n2wash.com" }],
      "destination": "https://carfect.pl/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "n2wash.com" }],
      "destination": "https://carfect.pl/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "(?<slug>.*)\\.admin\\.n2wash\\.com" }],
      "destination": "https://$slug.admin.carfect.pl/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "(?<slug>.*)\\.n2wash\\.com" }],
      "destination": "https://$slug.carfect.pl/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "authorization, content-type, apikey" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
