{
  "buildCommand": "cd ../.. && pnpm --filter hiservice run build",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install",
  "framework": "vite",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ../../libs/ .",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
