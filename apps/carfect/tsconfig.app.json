{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noFallthroughCasesInSwitch": false,
    "strictNullChecks": false,
    "paths": {
      "@/*": ["./src/*"],
      "@shared/pdf": ["../../libs/pdf/src/index.ts"],
      "@shared/ui": ["../../libs/ui/src/index.ts"],
      "@shared/ui/*": ["../../libs/ui/src/*"],
      "@shared/utils": ["../../libs/shared-utils/src/index.ts"],
      "@shared/invoicing": ["../../libs/shared-invoicing/src/index.ts"],
      "@shared/invoicing/*": ["../../libs/shared-invoicing/src/*"],
      "@shared/ai": ["../../libs/ai/src/index.ts"],
      "@shared/ai/*": ["../../libs/ai/src/*"],
      "@shared/custom-fields": ["../../libs/custom-fields/src/index.ts"],
      "@shared/custom-fields/*": ["../../libs/custom-fields/src/*"],
      "@shared/protocol-config": ["../../libs/protocol-config/src/index.ts"],
      "@shared/protocol-config/*": ["../../libs/protocol-config/src/*"]
    }
  },
  "include": [
    "src",
    "../../libs/ui/src",
    "../../libs/shared-utils/src",
    "../../libs/shared-invoicing/src",
    "../../libs/ai/src",
    "../../libs/pdf/src",
    "../../libs/custom-fields/src",
    "../../libs/protocol-config/src"
  ]
}
