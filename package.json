{
  "name": "@carfect/monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "nx run carfect:dev",
    "build": "nx run carfect:build",
    "lint": "nx run-many --target=lint",
    "dev:carfect": "nx run carfect:dev",
    "dev:hiservice": "nx run hiservice:dev",
    "build:hiservice": "nx run hiservice:build",
    "dev:landing": "nx run carfect-landing-page:dev",
    "build:landing": "nx run carfect-landing-page:build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nx": "^21.3.2",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    }
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@supabase/supabase-js": "^2.99.3",
    "ai": "^6.0.134",
    "dompurify": "^3.3.3",
    "zod": "^3.25.76"
  }
